{
  "name": "dvkeramik-telegram-miniapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0\" \"node --watch server/index.js\"",
    "build": "vite build",
    "start": "node server/index.js",
    "db:migrate": "node server/migrate.js",
    "import:dvkeramik": "node server/import-cli.js",
    "check": "node --check server/db.js && node --check server/catalog.js && node --check server/importer.js && node --check server/orders.js && node --check server/telegram.js && node --check server/admin.js && node --check server/visits.js && node --check server/index.js && vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.2",
    "lucide-react": "^0.561.0",
    "pg": "^8.22.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "slugify": "^1.6.6",
    "vite": "^7.3.0"
  },
  "devDependencies": {}
}
